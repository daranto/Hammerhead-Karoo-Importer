# Server
PORT=3001
NODE_ENV=production

# Session (generate with: openssl rand -hex 32)
SESSION_SECRET=change_me_to_a_random_32_byte_hex_string

# App URL (used as OAuth redirect base)
SERVER_BASE_URL=http://localhost:3001

# SQLite database path (inside Docker volume)
DB_PATH=/app/data/hammerhead.db
